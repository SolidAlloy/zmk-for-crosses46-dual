#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <scroll-snap.dtsi>
#include <behaviors/num_word.dtsi>

&caps_word {
	// Tells Caps Word to stay alive if you type an underscore, minus, or backspace
	continue-list = <MINUS LSHIFT BACKSPACE DELETE>;
};

&num_word {
	continue-list = <DOT COMMA BACKSPACE DELETE>;
};

/ {
    macros {
        lang_en: lang_en {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LC(LS(N1))>, <&macro_pause_for_release>, <&to 0>; 
        };
		
		lang_ua: lang_ua {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LC(LS(N2))>, <&macro_pause_for_release>, <&to 1>; 
        };
		
		lang_jp: lang_jp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LC(LS(N3))>, <&macro_pause_for_release>, <&to 0>; 
        };
		
		snap_left: snap_left {
			compatible = "zmk,behavior-macro";
			#binding-cells = <0>;
			bindings
				= <&macro_press &kp LGUI>
				, <&macro_tap &kp LEFT>
				, <&macro_release &kp LGUI>;
		};

		snap_right: snap_right {
			compatible = "zmk,behavior-macro";
			#binding-cells = <0>;
			bindings
				= <&macro_press &kp LGUI>
				, <&macro_tap &kp RIGHT>
				, <&macro_release &kp LGUI>;
		};
		
		mod_click: mod_click {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
			// Give the OS 30ms to register the modifier before sending the click
            wait-ms = <30>; 
            tap-ms = <30>;
			bindings
                = <&macro_param_1to1>
                , <&macro_press &kp MACRO_PLACEHOLDER>         // 1. Hold Control down
                , <&macro_press &mkp LCLK>                     // 2. Hold Left Click down
                , <&macro_pause_for_release>                   // 3. WAIT here until the physical key is released
                , <&macro_release &mkp LCLK>                   // 4. Release Left Click
                , <&macro_param_1to1>                          // <--- ADD THIS LINE HERE
                , <&macro_release &kp MACRO_PLACEHOLDER>       // 5. Release Control
                ;
        };
		
		task_mgr: task_mgr {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>;
            tap-ms = <10>;
            
            bindings
                = <&macro_press &kp LCTRL>             // 1. Hold Control
                , <&macro_press &kp LSHIFT>            // 2. Hold Shift
                , <&macro_press &kp ESC>               // 3. Hold Escape (Changed from tap)
                , <&macro_pause_for_release>           // 4. WAIT: Hold all 3 until you lift your finger
                , <&macro_release &kp ESC>             // 5. Release Escape
                , <&macro_release &kp LSHIFT>          // 6. Release Shift
                , <&macro_release &kp LCTRL>           // 7. Release Control
                ;
        };
		
		mo_mod: mo_mod {
            compatible = "zmk,behavior-macro-two-param";
            #binding-cells = <2>;
            wait-ms = <0>;
            tap-ms = <0>;
            
            bindings
                = <&macro_param_2to1>                            // 1. Grab Param 2 (The Modifier)
                , <&macro_press &kp MACRO_PLACEHOLDER>           // 2. Inject it and press it down
                , <&macro_param_1to1>                            // 3. Grab Param 1 (The Layer)
                , <&macro_press &mo MACRO_PLACEHOLDER>           // 4. Inject it and activate layer            
                , <&macro_pause_for_release>                     // 5. WAIT here while you hold the combo
                , <&macro_param_1to1>                            // 6. Grab Param 1 (The Layer) again
                , <&macro_release &mo MACRO_PLACEHOLDER>         // 7. Deactivate the layer
                , <&macro_param_2to1>                            // 8. Grab Param 2 (The Modifier) again
                , <&macro_release &kp MACRO_PLACEHOLDER>         // 9. Release the modifier
                ;
        };
		
		mo_cw_break: mo_caps_word_break {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings
                = <&macro_tap &kp F24>                    // 1. Instantly kill caps_word
                , <&macro_param_1to1>
                , <&macro_press &mo MACRO_PLACEHOLDER>   // 2. Press your target layer
                , <&macro_pause_for_release>
                , <&macro_param_1to1>
                , <&macro_release &mo MACRO_PLACEHOLDER> // 3. Release the layer
                ;
        };
		

    };
	
	behaviors {
        alt_tab: alt_tab {
            compatible = "zmk,behavior-tri-state";
            #binding-cells = <0>;
            
            // 1st: Toggle Alt ON. 2nd: Tap Tab. 3rd: Toggle Alt OFF on interrupt.
            bindings = <&kt LALT>, <&kp TAB>, <&kt LALT>;
            
            // Optional: If you want to use Shift+Tab to cycle backwards without 
            // closing the menu, you can add the physical key-position of your 
            // Shift key to this array.
            // ignored-key-positions = < >; 
        };
		
		// Home Row Mod for the LEFT hand (Triggers only if a RIGHT hand key is pressed)
        hrm_left: hrm_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            quick-tap-ms = <120>;
            require-prior-idle-ms = <120>; // Highly recommended for HRM to prevent mid-word misfires
            bindings = <&kp>, <&kp>;
            // The array of all RIGHT-hand keys
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 42 43 44 45 46 47 51 52 53 49>;
        };

        // Home Row Mod for the RIGHT hand (Triggers only if a LEFT hand key is pressed)
        hrm_right: hrm_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            quick-tap-ms = <120>;
            require-prior-idle-ms = <120>; 
            bindings = <&kp>, <&kp>;
            // The array of all LEFT-hand keys
            hold-trigger-key-positions = <0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29 36 37 38 39 40 41 48 49 50>;
        };
		
		// Home Row Mod for the LEFT hand (Triggers only if a RIGHT hand key is pressed)
        mo_left: mo_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            require-prior-idle-ms = <120>; // Highly recommended for HRM to prevent mid-word misfires
            bindings = <&mo>, <&kp>;
            // The array of all RIGHT-hand keys
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 42 43 44 45 46 47 51 52 53>;
			hold-trigger-on-release;
        };
		
		// Home Row Mod for the RIGHT hand (Triggers only if a LEFT hand key is pressed)
        mo_right: mo_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            require-prior-idle-ms = <120>; 
            bindings = <&mo>, <&kp>;
            // The array of all LEFT-hand keys
            hold-trigger-key-positions = <0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29 36 37 38 39 40 41 48 49 50>;
			hold-trigger-on-release;
        };
		
		mo_tab: mo_tab {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            require-prior-idle-ms = <120>; // Highly recommended for HRM to prevent mid-word misfires
            bindings = <&mo>, <&kp>;
            // The array of all RIGHT-hand keys
            hold-trigger-key-positions = <0 5 40 41>;
			hold-trigger-on-release;
        };
		
        mo_mouse: mo_mouse {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            require-prior-idle-ms = <120>; // Highly recommended for HRM to prevent mid-word misfires
            bindings = <&mo>, <&kp>;
            // The array of all RIGHT-hand keys
            hold-trigger-key-positions = <27 28 29 40 41>;
			hold-trigger-on-release;
        };
		
		lt_scroll: layer_tap_scroll {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <170>;
			require-prior-idle-ms = <120>; 
            bindings = <&mo>, <&kp>;
			hold-trigger-key-positions = <48>; // a key that will certainly not be used for rolling. Everything else should result in tap.
        };
		
        caps_ctrl: caps_ctrl {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <170>;
            bindings = <&kp>, <&caps_word>;
        };
    };
	
	combos {
        compatible = "zmk,combos";

        combo_nav_shift {
            timeout-ms = <50>;
            key-positions = <27 28>; 
            bindings = <&mo_mod 7 LSHIFT>; 
        };

        combo_nav_ctrl {
            timeout-ms = <50>;
            key-positions = <26 28>;
            bindings = <&mo_mod 7 LCTRL>; 
        };
		
        combo_nav_shift_ctrl {
            timeout-ms = <50>;
            key-positions = <26 27 28>; 
            bindings = <&mo_mod 7 LC(LSHIFT)>; 
        };
		
		combo_nav_alt {
            timeout-ms = <50>;
            key-positions = <25 28>; 
            bindings = <&mo_mod 7 LALT>; 
        };
		
		combo_snipe {
            timeout-ms = <50>;
            key-positions = <25 26>; 
            bindings = <&mo 4>;
        };
		
		combo_num_ctrl {
            timeout-ms = <50>;
            key-positions = <33 51>; 
            bindings = <&mo_mod 5 LCTRL>; 
        };
		
		combo_num_f {
            timeout-ms = <50>;
            key-positions = <33 52>; 
            bindings = <&mo 6>; 
        };
		
		combo_shortcut_shift {
            timeout-ms = <50>;
            key-positions = <36 49>; 
            bindings = <&mo_mod 2 LSHIFT>; 
        };
		
		combo_shift_tab {
            timeout-ms = <50>;
            key-positions = <27 49>; 
            bindings = <&kp LS(TAB)>;
        };
		
		combo_colon_en {
            timeout-ms = <50>;
            key-positions = <26 27>; 
            bindings = <&kp LS(SEMI)>;
			layers = <0>;
        };
		
		combo_colon_ua {
            timeout-ms = <50>;
            key-positions = <26 27>; 
            bindings = <&kp LS(N6)>;
			layers = <2>;
        };
        
        combo_plus {
            timeout-ms = <50>;
            key-positions = <31 32>; 
            bindings = <&kp LS(EQUAL)>;
        };
        
        combo_underscore {
