            bindings = <&kp LS(GRAVE)>;
        };
		        
        combo_grave {
            timeout-ms = <50>;
            key-positions = <44 45 46>;
            bindings = <&kp GRAVE>;
        };
        
        combo_dollar_en {
            timeout-ms = <50>;
            key-positions = <14 15>;
            bindings = <&kp LS(N4)>;
			layers = <0>;
        };
		
		combo_uah_ua {
            timeout-ms = <50>;
