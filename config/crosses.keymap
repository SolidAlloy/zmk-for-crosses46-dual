        };
        
        combo_multiply {
            timeout-ms = <50>;
            key-positions = <33 34>; 
            bindings = <&kp LS(N8)>;
        };
		
		combo_exclamation {
            timeout-ms = <50>;
            key-positions = <25 26 27>; 
            bindings = <&kp LS(N1)>;
        };
        
        combo_slash_en {
            timeout-ms = <50>;
            key-positions = <31 33>; 
            bindings = <&kp FSLH>;
			layers = <0>;
        }; 
		
		combo_slash_ua {
            timeout-ms = <50>;
            key-positions = <31 33>; 
            bindings = <&kp LS(BSLH)>;
			layers = <2>;
        };
        
        combo_question_en {
            timeout-ms = <50>;
            key-positions = <31 34>; 
            bindings = <&kp LS(FSLH)>;
			layers = <0>;
        };
		
		combo_question_ua {
            timeout-ms = <50>;
            key-positions = <31 34>; 
            bindings = <&kp LS(N7)>;
			layers = <2>;
        };
		
		combo_pipe_en {
            timeout-ms = <50>;
            key-positions = <31 32 33>; 
            bindings = <&kp LS(BSLH)>;
			layers = <0>;
        };
		
		combo_hyphen_ua {
            timeout-ms = <50>;
            key-positions = <31 32 33>; 
            bindings = <&kp MINUS>;
			layers = <2>;
        };
		
		combo_percent {
