    chosen { zmk,physical-layout = &gggw_crosses_54_layout; };

    keymap {
        compatible = "zmk,keymap";
        base_layer {
            display-name = "Base";
            bindings = <
                &none &none &none &none &none &none   &none &none  &none     &none   &none    &none
                &kp ESC   &kp Z  &kp P  &kp D  &kp L  &kp X    &kp EQUAL &kp U  &kp O     &kp Y   &kp Q    &kp BSPC
                &kp W &kp S  &mo_mouse 3 N  &hrm_left LSHIFT T  &mo_left 7 H  &kp K    &kp MINUS &mo_right 7 E  &hrm_right RSHIFT A  &mo_right 5 I   &kp C &kp B
                &mo_cw_break 2 &kp V  &kp F  &lt_scroll 8 G  &kp M  &kp J    &kp SEMI &kp APOS  &kp DOT &kp COMMA &kp LS(APOS) &caps_ctrl RCTRL 0
                        &kp LGUI   &mo_tab 4 TAB    &kp R    &kp SPACE    &kp RET    &kp LALT
            >;
        };
		
		ua_layer {
            display-name = "Ukrainian";
            bindings = <
                &none &none &none &none &none &none   &none &none  &none     &none   &none    &none
                &kp ESC   &kp A  &kp O  &kp E  &kp DOT  &kp APOS    &kp U &kp G  &kp K     &kp COMMA   &kp SEMI    &kp BSPC
                &kp Q &kp H  &mo_mouse 3 F  &hrm_left LSHIFT J  &mo_left 7 T  &kp S    &kp V &mo_right 7 D  &hrm_right RSHIFT Y  &mo_right 5 N   &kp C &kp P
                &mo_cw_break 2 &kp W  &kp M  &lt_scroll 8 Z  &kp B  &kp RIGHT_BRACKET    &kp LEFT_BRACKET  &kp R  &kp FSLH &kp LS(FSLH) &kp X &caps_word
                        &kp LGUI   &mo_tab 4 I    &kp L    &kp SPACE    &kp RET    &kp LALT
            >;
        };

        shortcuts_layer {
            display-name = "Shortcuts";
            bindings = <
                &none &none &none &none &none &none   &none &none  &none     &none   &none    &none
                &kp LC(TAB)    &kp LC(Q)     &kp LC(W)     &kp LC(E)     &kp LC(R)     &kp LC(T)     &kp LC(EQUAL)   &none &none   &none    &none &kp LC(BSPC)
                &kp LC(LS(Z))    &kp LC(A)     &kp LC(S)     &kp LC(D)     &kp LC(F)     &kp LC(H)      &kp LC(MINUS)    &none   &kp LC(UP)   &kp LC(HOME)   &kp LC(END)   &none
                &none    &kp LC(Z)     &kp LC(X)    &kp LC(C)     &kp LC(V)     &kp LC(B)      &kp LC(N)   &kp LC(LEFT)    &kp LC(DOWN)    &kp LC(RIGHT)   &kp LC(PAGE_UP) &kp LC(PAGE_DOWN)
                                            &trans     &kp LSHIFT       &trans      &trans  &trans   &trans
            >;
        };

        mouse_layer {
            display-name = "Mouse";
            bindings = <
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &none     &none     &mod_click LCTRL     &none     &none       &none     &none       &none       &none       &none
                &none     &mo 4     &none     &mkp RCLK  &mkp LCLK    &mod_click LSHFT    &none    &none    &none   &none    &none    &none
                &none      &none    &none     &mo 8     &mkp MCLK     &mod_click LALT     &none     &none       &none     &none       &none       &none
                                                     &none         &none     &kp SPACE     &none     &none     &none     
            >;
        };
		
		snipe_layer {
			display-name = "Snipe";
			bindings = <
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &alt_tab         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &trans  &trans  &trans  &none     &none  &none      &none      &none   &none       &none
                &none         &none     &none     &none     &kp LG(V)   &kp LG(LS(S))     &none           &none    &none   &none   &none       &none
                                                     &none     &none     &none     &none       &none     &none     
            >;
		};
		
		num_layer {
			display-name = "Numbers";
			bindings = <
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &kp N7     &kp N8     &kp N9     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &kp N4     &kp N5     &kp N6     &none  &none    &none  &none     &none   &none  &none
                &none         &kp N0    &kp N1     &kp N2     &kp N3     &none     &none    &none  &none     &none   &none  &none
                                                     &none     &kp COMMA     &kp DOT     &kp LCTRL       &mo 6     &none     
            >;
		};
		
		ctrl_num_layer {
			display-name = "F Numbers";
			bindings = <
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &kp F12     &kp F7     &kp F8     &kp F9     &none     &none     &none       &none     &none       &none       &none
                &none         &kp F11     &kp F4     &kp F5     &kp F6  &none     &none     &none       &none     &none       &none       &none
                &none         &kp F10    &kp F1     &kp F2     &kp F3  &none     &none       &none     &none       &none       &none       &none
                                                                &none     &kp LALT    &kp LCTRL     &none       &none     &none
            >;
		};
		
		helpers_layer {
            display-name = "Helpers";
            bindings = <
                &task_mgr   &none     &none     &none     &none     &none     &none       &none     &none       &none       &none    &none
                &none		&none    &kp LA(W)       &kp C_BRI_DEC   &kp C_BRI_INC   &none    &none    &snap_right   &kp LG(DOWN)   &kp LG(UP)   &snap_left    &kp DEL
                &none   &kp LALT   &kp LCTRL    &kp LSHIFT       &none    &kp C_PLAY_PAUSE     &kp LS(F3)       &kp LEFT    &kp DOWN    &kp UP   &kp RIGHT       &none
                &none   &kp C_MUTE   &kp C_VOLUME_DOWN    &kp C_VOLUME_UP    &none       &none     &kp F3    &kp HOME   &kp END     &kp PAGE_UP    &kp PAGE_DOWN   &none
                                                     &kp LG(P)   &trans   &trans     &lang_en    &lang_ua    &lang_jp     
            >;
        };
		
		scroll_layer {
			display-name = "Scroll";
			bindings = <
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                &none         &none     &none     &none     &none     &none     &none       &none     &none       &none       &none       &none
                                                     &none     &none     &none     &none       &none     &none     
            >;
		};
    };
};
